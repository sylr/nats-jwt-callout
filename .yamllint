# vim: ft=yaml:
# code: language=yaml
---
yaml-files:
- ".yamllint"
- "*.yaml.age"
- "*.yaml"
- "*.yml.age"
- "*.yml"
rules:
  indentation:
    spaces: 2
    indent-sequences: false
    ignore: |
      **/helm-values.yaml
  document-start:
    present: true
    ignore: ""
ignore: |
  .git/
  .venv/
  dist/
