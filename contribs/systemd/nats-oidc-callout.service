[Unit]
Description=NATS auth callout service (OIDC token authentication)
Documentation=https://github.com/sylr/nats-oidc-callout
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=nats-oidc-callout
Group=nats-oidc-callout
ExecStart=/usr/bin/nats-oidc-callout -config /etc/nats-oidc-callout/config.yaml
# `systemctl reload nats-oidc-callout` hot-reloads the policy and issuers (SIGHUP).
ExecReload=/bin/kill -HUP $MAINPID
Restart=on-failure
RestartSec=5s

# Hardening
NoNewPrivileges=yes
ProtectSystem=strict
ProtectHome=yes
PrivateTmp=yes
PrivateDevices=yes
ProtectKernelTunables=yes
ProtectKernelModules=yes
ProtectControlGroups=yes
RestrictAddressFamilies=AF_INET AF_INET6 AF_UNIX
RestrictNamespaces=yes
LockPersonality=yes
MemoryDenyWriteExecute=yes
SystemCallArchitectures=native
SystemCallFilter=@system-service
SystemCallFilter=~@privileged @resources
# Stateless network service: ProtectSystem=strict already makes the whole
# filesystem (incl. /etc, which holds the secret-bearing config) read-only, and
# the service writes nothing to disk — so no ReadWritePaths/StateDirectory.

[Install]
WantedBy=multi-user.target
